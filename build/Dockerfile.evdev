# Build evdev wheel
# Usage:
#   docker build -f build/Dockerfile.evdev -t evdev-builder build/
#   docker run --rm -v $(pwd):/output evdev-builder
#   uv pip install evdev-*.whl

FROM python:3.11-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    linux-headers-generic \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /wheels
RUN pip wheel evdev --no-deps -w .

# Copy wheel to mounted /output
CMD cp /wheels/*.whl /output/
