# syntax=docker/dockerfile:1
# Test voxtype install on Arch Linux
FROM archlinux:latest

RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    pacman -Syu --noconfirm sudo

# Install system deps (cached)
RUN pacman -S --noconfirm \
    portaudio \
    espeak-ng \
    libappindicator-gtk3 \
    gobject-introspection cairo \
    base-devel pkg-config \
    xorg-server-xvfb dbus

# Install uv and create venv (cached)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"
RUN uv venv --python 3.11 --seed /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy ONLY dependency files first
COPY pyproject.toml /app/
COPY _openvip_sdk/ /app/_openvip_sdk/

WORKDIR /app

# Install dependencies (cached if pyproject.toml doesn't change)
RUN pip install /app/_openvip_sdk && \
    pip install ".[tts]" && \
    pip install PyGObject pycairo

# NOW copy the rest of the code
COPY --chown=testuser:testuser . /app/

# Install voxtype editable (fast, no deps)
RUN pip install -e . --no-deps

USER testuser

# Verify installation
RUN bash -c '\
    python -m voxtype --version && \
    echo "Testing PyGObject + AppIndicator..." && \
    python -c "import gi; gi.require_version(\"Gtk\", \"3.0\"); from gi.repository import Gtk; print(\"PyGObject OK\")" && \
    python -c "import gi; gi.require_version(\"AppIndicator3\", \"0.1\"); from gi.repository import AppIndicator3; print(\"AppIndicator OK\")" && \
    echo "Testing tray module import..." && \
    python -c "from voxtype.tray.app import TrayApp; print(\"TrayApp import OK\")" && \
    echo "SUCCESS: Arch install test passed"'
