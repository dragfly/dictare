# syntax=docker/dockerfile:1
# Test voxtype install on Arch Linux
FROM archlinux:latest

RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    pacman -Syu --noconfirm sudo

# Install system deps (cacheable)
RUN pacman -S --noconfirm \
    portaudio \
    espeak-ng \
    libappindicator-gtk3 \
    gobject-introspection cairo \
    base-devel pkg-config \
    xorg-server-xvfb dbus

# Install uv (cacheable)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

COPY --chown=testuser:testuser . /home/testuser/voxtype
WORKDIR /home/testuser/voxtype

USER testuser

# Install Python deps with cache mount
RUN --mount=type=cache,target=/home/testuser/.cache/pip,uid=1000 \
    --mount=type=cache,target=/home/testuser/.cache/uv,uid=1000 \
    bash -c '\
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH" && \
    uv venv --python 3.11 --seed .venv && \
    .venv/bin/pip install ./_openvip_sdk && \
    .venv/bin/pip install -e ".[tts]" && \
    .venv/bin/pip install PyGObject pycairo'

# Verify installation
RUN bash -c '\
    .venv/bin/python -m voxtype --version && \
    echo "Testing PyGObject + AppIndicator..." && \
    .venv/bin/python -c "import gi; gi.require_version(\"Gtk\", \"3.0\"); from gi.repository import Gtk; print(\"PyGObject OK\")" && \
    .venv/bin/python -c "import gi; gi.require_version(\"AppIndicator3\", \"0.1\"); from gi.repository import AppIndicator3; print(\"AppIndicator OK\")" && \
    echo "Testing tray module import..." && \
    .venv/bin/python -c "from voxtype.tray.app import TrayApp; print(\"TrayApp import OK\")" && \
    echo "SUCCESS: Arch install test passed"'
