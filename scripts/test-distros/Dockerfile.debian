# syntax=docker/dockerfile:1
# Test voxtype install on Debian 12 (Bookworm)
FROM debian:12

ENV DEBIAN_FRONTEND=noninteractive

RUN useradd -m -s /bin/bash testuser && \
    apt-get update && \
    apt-get install -y sudo curl && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Install system deps + python3-gi (PyGObject from PyPI needs girepository-2.0 not in Bookworm)
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv python3-dev \
    python3-gi python3-gi-cairo gir1.2-ayatanaappindicator3-0.1 \
    libportaudio2 portaudio19-dev \
    espeak-ng \
    build-essential pkg-config \
    xvfb dbus-x11

# Create venv with system-site-packages for python3-gi
RUN python3 -m venv --system-site-packages /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --upgrade pip

# Copy ONLY dependency files first
COPY pyproject.toml /app/
COPY _openvip_sdk/ /app/_openvip_sdk/

WORKDIR /app

# Install dependencies (cached if pyproject.toml doesn't change)
RUN pip install /app/_openvip_sdk && \
    pip install ".[tts]"

# NOW copy the rest of the code
COPY --chown=testuser:testuser . /app/

# Install voxtype editable (fast, no deps)
RUN pip install -e . --no-deps

USER testuser

# Verify installation
RUN bash -c '\
    python -m voxtype --version && \
    echo "Testing PyGObject + AppIndicator..." && \
    python -c "import gi; gi.require_version(\"Gtk\", \"3.0\"); from gi.repository import Gtk; print(\"PyGObject OK\")" && \
    python -c "import gi; gi.require_version(\"AyatanaAppIndicator3\", \"0.1\"); from gi.repository import AyatanaAppIndicator3; print(\"AppIndicator OK\")" && \
    echo "Testing tray module import..." && \
    python -c "from voxtype.tray.app import TrayApp; print(\"TrayApp import OK\")" && \
    echo "SUCCESS: Debian install test passed"'
