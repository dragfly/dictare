# syntax=docker/dockerfile:1
# Test dictare install on Debian 12 (Bookworm)
FROM debian:12

ENV DEBIAN_FRONTEND=noninteractive

# Install system deps + python3-gi (PyGObject from PyPI needs girepository-2.0 not in Bookworm)
RUN apt-get update && apt-get install -y \
    curl \
    python3 python3-pip python3-venv python3-dev \
    python3-gi python3-gi-cairo gir1.2-ayatanaappindicator3-0.1 \
    libportaudio2 portaudio19-dev \
    espeak-ng \
    build-essential pkg-config \
    xvfb dbus-x11

# Create venv with system-site-packages for python3-gi
RUN python3 -m venv --system-site-packages /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --upgrade pip

# Copy dependency files (hatch needs pyproject.toml, __init__.py, README.md)
COPY pyproject.toml README.md /app/
COPY src/dictare/__init__.py /app/src/dictare/
COPY _openvip_sdk/ /app/_openvip_sdk/

WORKDIR /app

# Install dependencies (cached if pyproject.toml doesn't change)
RUN pip install /app/_openvip_sdk && \
    pip install .

# Copy the rest of the code
COPY . /app/

# Make test scripts executable
RUN chmod +x /app/scripts/test-distros/tests/*.sh

# Install dictare editable (fast, no deps)
RUN pip install -e . --no-deps

# Run smoke test (verifies imports work)
RUN /app/scripts/test-distros/tests/smoke.sh
