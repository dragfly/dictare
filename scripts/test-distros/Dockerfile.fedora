# syntax=docker/dockerfile:1
# Test voxtype install on Fedora 40
FROM fedora:40

# Install system deps (cached)
RUN dnf install -y \
    curl \
    portaudio portaudio-devel \
    espeak-ng \
    libappindicator-gtk3 \
    gobject-introspection-devel cairo-devel cairo-gobject-devel \
    gcc pkg-config python3-devel \
    xorg-x11-server-Xvfb dbus-x11

# Install uv and create venv (cached)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"
RUN uv venv --python 3.11 --seed /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy dependency files (hatch needs pyproject.toml, __init__.py, README.md)
COPY pyproject.toml README.md /app/
COPY src/voxtype/__init__.py /app/src/voxtype/
COPY _openvip_sdk/ /app/_openvip_sdk/

WORKDIR /app

# Install dependencies (cached if pyproject.toml doesn't change)
RUN pip install /app/_openvip_sdk && \
    pip install ".[tts]" && \
    pip install PyGObject pycairo

# Copy the rest of the code
COPY . /app/

# Make test scripts executable
RUN chmod +x /app/scripts/test-distros/tests/*.sh

# Install voxtype editable (fast, no deps)
RUN pip install -e . --no-deps

# Run smoke test (verifies imports work)
RUN /app/scripts/test-distros/tests/smoke.sh
