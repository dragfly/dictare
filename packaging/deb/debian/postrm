#!/bin/bash
set -e

if [ "$1" = "purge" ] || [ "$1" = "remove" ]; then
    # Remove dictare venv
    rm -rf /opt/dictare

    # Remove ydotoold service file
    SUDO_USER_HOME=$(eval echo "~${SUDO_USER:-$USER}")
    rm -f "${SUDO_USER_HOME}/.config/systemd/user/ydotoold.service"

    if [ -n "$SUDO_USER" ]; then
        su - "$SUDO_USER" -c "systemctl --user daemon-reload 2>/dev/null || true"
    fi
fi
